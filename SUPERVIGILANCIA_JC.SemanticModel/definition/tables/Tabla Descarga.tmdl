	partition 'Tabla Descarga' = m
		mode: import
		source =
				let
				    Origen = Table.NestedJoin(RECLAMO, {"IdRegion"}, REGION, {"IDREGION"}, "REGION", JoinKind.LeftOuter),
				    #"Se expandió REGION" = Table.ExpandTableColumn(Origen, "REGION", {"IDREGION", "REGION"}, {"REGION.IDREGION", "REGION.REGION"}),
				    #"Consultas combinadas" = Table.NestedJoin(#"Se expandió REGION", {"IdComuna"}, COMUNA, {"IDCOMUNA"}, "COMUNA", JoinKind.LeftOuter),
				    #"Se expandió COMUNA" = Table.ExpandTableColumn(#"Consultas combinadas", "COMUNA", {"IDCOMUNA", "COMUNA", "REGION"}, {"COMUNA.IDCOMUNA", "COMUNA.COMUNA", "COMUNA.REGION"}),

				    #"Se expandió FASE RECLAMO" = Table.ExpandTableColumn(#"Consultas combinadas1", "FASE RECLAMO", {"IDFASE", "RECLAMO"}, {"FASE RECLAMO.IDFASE", "FASE RECLAMO.RECLAMO"}),

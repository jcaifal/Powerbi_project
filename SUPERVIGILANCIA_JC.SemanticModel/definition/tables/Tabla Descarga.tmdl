				    #"Se expandió TIPO_TRAMITE" = Table.ExpandTableColumn(#"Consultas combinadas2", "TIPO_TRAMITE", {"Descripcion"}, {"TIPO_TRAMITE.Descripcion"}),
				    #"Consultas combinadas3" = Table.NestedJoin(#"Se expandió TIPO_TRAMITE", {"IdTipoReclamo"}, TIPO_RECLAMO, {"IdTipoReclamo"}, "TIPO_RECLAMO", JoinKind.LeftOuter),
				    #"Se expandió TIPO_RECLAMO" = Table.ExpandTableColumn(#"Consultas combinadas3", "TIPO_RECLAMO", {"Descripcion"}, {"TIPO_RECLAMO.Descripcion"}),
				    #"Consultas combinadas4" = Table.NestedJoin(#"Se expandió TIPO_RECLAMO", {"IdEstado"}, ESTADO_SUPERVIGILANCIA, {"IDESTADO"}, "ESTADO_SUPERVIGILANCIA", JoinKind.LeftOuter),
				    #"Se expandió ESTADO_SUPERVIGILANCIA" = Table.ExpandTableColumn(#"Consultas combinadas4", "ESTADO_SUPERVIGILANCIA", {"ESTADODESCRIPCION"}, {"ESTADO_SUPERVIGILANCIA.ESTADODESCRIPCION"}),
